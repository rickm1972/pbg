VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

VITE_ADMIN_PASSWORD="change-me"

# Optional: database password for `npm run db:repair` (adds target_url / walmart_url columns)
# SUPABASE_DB_PASSWORD=

# Agent 1 — Product Evidence Agent (`npm run agent1`)
# PERPLEXITY_API_KEY=          # Stage 1b: Perplexity Search (manufacturer, materials, SDS)
# ANTHROPIC_API_KEY=           # Stage 1a: Amazon web_search (1 call) + Stage 2: synthesis
# AGENT1_PROVIDER=perplexity_search   # default | anthropic (legacy single-call web search)
# AGENT1_ANTHROPIC_MODEL=claude-sonnet-4-6
# AGENT1_AMAZON_WEB_SEARCH_MAX_USES=1   # one search; allowed_domains = hostname of amazon_url
# AGENT1_AMAZON_MAX_TOKENS=4000        # cap Amazon-stage output tokens
# AGENT1_PERPLEXITY_MAX_RESULTS=5
# AGENT1_PERPLEXITY_MAX_TOKENS_PER_PAGE=1000
# AGENT1_WEB_SEARCH_TYPE=web_search_20250305
# AGENT1_MAX_WEB_SEARCH_USES=12   # legacy AGENT1_PROVIDER=anthropic only
# AGENT1_MAX_TOKENS=12000
# SUPABASE_SERVICE_ROLE_KEY=   # required for agent writes
# VITE_AGENT1_API_URL=http://localhost:8787/agent1   # optional; dev uses /api/agent1 proxy

# Persona agent — buyer personas (`npm run persona "target segment"`)
# Uses Perplexity Sonar Pro (retrieval) + Claude Sonnet 4.6 (synthesis). Admin UI: /admin → Personas tab.
# PERPLEXITY_API_KEY=           # Stage 1: sonar-pro chat (not the Agent 1 Search API)
# ANTHROPIC_API_KEY=            # Stage 2: synthesis only (no web search tool)
# PERSONA_PERPLEXITY_MODEL=sonar-pro
# PERSONA_ANTHROPIC_MODEL=claude-sonnet-4-6
# PERSONA_MAX_TOKENS=8000
# PERSONA_PERPLEXITY_INPUT_PER_M=3
# PERSONA_PERPLEXITY_OUTPUT_PER_M=15
# PERSONA_PERPLEXITY_REQUEST_FEE_USD=0
# SUPABASE_SERVICE_ROLE_KEY=    # required for persona runs from dev API / CLI
# VITE_PERSONA_API_URL=/api/persona   # optional; dev uses Vite middleware proxy
# PERSONA_EXPORT_BASE_URL=http://127.0.0.1:5173   # URL Playwright opens for PDF export (dev server must be running)
# PDF export requires: npm run playwright:install  (one-time Chromium download)

# Channel Discovery agent — topic channel maps (`npm run channel "plastic exposure"`)
# Uses Perplexity Sonar Pro (retrieval) + Claude Sonnet 4.6 (synthesis). Admin UI: /admin → Channels tab.
# CHANNEL_PERPLEXITY_MODEL=sonar-pro
# CHANNEL_ANTHROPIC_MODEL=claude-sonnet-4-6
# CHANNEL_MAX_TOKENS=12000
# VITE_CHANNEL_API_URL=/api/channel   # optional; dev uses Vite middleware proxy
# CHANNEL_EXPORT_BASE_URL=http://127.0.0.1:5173   # Playwright PDF export base URL

# Agent 2 — Input Normalization Agent (`npm run agent2`)
# AGENT2_ANTHROPIC_MODEL=claude-sonnet-4-20250514
# AGENT2_MAX_TOKENS=8192
# VITE_AGENT2_API_URL=http://localhost:8788/agent2   # optional; dev uses /api/agent2 proxy

