VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

VITE_ADMIN_PASSWORD="change-me"

# Optional: database password for `npm run db:repair` (adds target_url / walmart_url columns)
# SUPABASE_DB_PASSWORD=

# Agent 1 — Product Evidence Agent (`npm run agent1`)
# PERPLEXITY_API_KEY=          # Stage 1: Perplexity Search API retrieval
# ANTHROPIC_API_KEY=           # Stage 2: Claude synthesis (no web search tool)
# AGENT1_PROVIDER=perplexity_search   # default | anthropic (legacy web search)
# AGENT1_ANTHROPIC_MODEL=claude-sonnet-4-6
# AGENT1_PERPLEXITY_MAX_RESULTS=5
# AGENT1_PERPLEXITY_MAX_TOKENS_PER_PAGE=1000
# AGENT1_WEB_SEARCH_TYPE=web_search_20250305   # only if AGENT1_PROVIDER=anthropic
# AGENT1_MAX_WEB_SEARCH_USES=12
# AGENT1_MAX_TOKENS=12000
# SUPABASE_SERVICE_ROLE_KEY=   # required for agent writes
# VITE_AGENT1_API_URL=http://localhost:8787/agent1   # optional; dev uses /api/agent1 proxy

# Agent 2 — Input Normalization Agent (`npm run agent2`)
# AGENT2_ANTHROPIC_MODEL=claude-sonnet-4-20250514
# AGENT2_MAX_TOKENS=8192
# VITE_AGENT2_API_URL=http://localhost:8788/agent2   # optional; dev uses /api/agent2 proxy

