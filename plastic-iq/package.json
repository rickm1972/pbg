    "lint": "eslint .",
    "preview": "vite preview",
    "db:repair": "node scripts/apply-product-retailer-columns.mjs",
    "db:migrate:agent1": "node scripts/apply-agent1-migration.mjs",
    "db:migrate:agent2": "node scripts/apply-agent2-migration.mjs",
    "db:migrate:agent3": "node scripts/apply-product-scores-migration.mjs",
    "db:migrate:agent3-status": "node scripts/apply-scoring-review-pending-migration.mjs",
    "db:migrate:agent4": "node scripts/apply-product-qa-migration.mjs",
    "db:migrate:quiz": "node scripts/apply-quiz-responses-migration.mjs",
    "db:migrate:quiz:first-name": "node scripts/apply-quiz-first-name-migration.mjs",
