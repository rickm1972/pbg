    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "pg": "^8.13.1",
    "playwright": "^1.52.0",
    "postcss": "^8.5.14",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.2.0"
